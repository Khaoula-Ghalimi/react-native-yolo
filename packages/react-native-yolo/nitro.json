{
  "$schema": "https://nitro.margelo.com/nitro.schema.json",
  "cxxNamespace": [
    "yolo"
  ],
  "ios": {
    "iosModuleName": "Yolo"
  },
  "android": {
    "androidNamespace": [
      "yolo"
    ],
    "androidCxxLibName": "Yolo"
  },
  "autolinking": {
    "Yolo": {
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridYolo"
      },
      "android": {
        "language": "kotlin",
        "implementationClassName": "HybridYolo"
      }
    }
  },
  "ignorePaths": [
    "**/node_modules"
  ]
}